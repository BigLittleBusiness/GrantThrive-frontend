# GrantThrive Frontend Environment Variables
# ==========================================
# Copy this file to .env in the GrantThrive-frontend/ directory.
# These variables are used by the Vite build process for all UI apps.

# The full base URL of the backend API.
# This must be reachable from your browser.
VITE_API_URL="http://localhost:5000/api"

# The full URL of the main login page.
# This is used by the Admin Dashboard to redirect unauthenticated users.
VITE_LOGIN_URL="http://localhost:5173/login"
