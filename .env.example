# GrantThrive Frontend Environment Variables
# ==========================================
# Copy this file to .env in the GrantThrive-frontend/ directory.
# These variables are used by the Vite build process for all UI apps.

# ── API ──────────────────────────────────────────────────────────────────────

# The full base URL of the backend API.
# This must be reachable from your browser.
# Development:  http://localhost:5000/api
# Production:   https://api.grantthrive.com/api
VITE_API_URL="http://localhost:5000/api"

# ── Auth ─────────────────────────────────────────────────────────────────────

# The canonical login URL for the council portal.
# Used by the Admin Dashboard's AdminAuthGate when redirecting unauthenticated
# users who arrive at /admin/* via a direct link (e.g. from an email).
# NOTE: With the dedicated AdminLogin screen in place, this URL is only used
#       as a fallback for the AccessDenied "switch account" flow.
# Development:  http://localhost:5173/app/login
# Production:   https://app.grantthrive.com/login
VITE_LOGIN_URL="http://localhost:5173/app/login"

# ── Admin Login — Rate Limiting (backend) ────────────────────────────────────
# The AdminLogin component enforces client-side rate limiting (5 attempts,
# 15-minute lockout). For defence-in-depth, the backend /auth/login endpoint
# should ALSO enforce server-side rate limiting.
#
# Recommended backend settings (Flask-Limiter or equivalent):
#   POST /api/auth/login  →  10 requests / 15 minutes per IP
#   POST /api/auth/login  →  5  requests / 15 minutes per email address
#
# These values are intentionally NOT exposed as env vars here because they
# are backend configuration, not frontend. Set them in the backend's .env:
#   RATELIMIT_DEFAULT="10 per 15 minutes"
#   RATELIMIT_ADMIN_LOGIN="5 per 15 minutes"
